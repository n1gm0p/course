# Скопируй этот файл в .env и подставь свои значения.
# Файл .env не должен попадать в Git.

NODE_ENV=development
PORT=4000

# Домен фронтенда для CORS (в продакшене — например https://ваш-сайт.ru)
CORS_ORIGIN=http://localhost:5173

# Опционально: путь к файлу SQLite (относительно текущей рабочей директории при запуске server).
# По умолчанию создаётся server/database.db
# SQLITE_PATH=./database.db
